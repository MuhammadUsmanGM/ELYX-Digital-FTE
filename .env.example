# -----------------------------------------------------------------------------
# AI BRAIN SELECTION (Choose your reasoning engine)
# Options: claude, qwen, gemini, codex
# -----------------------------------------------------------------------------
ELYX_ACTIVE_BRAIN=claude
CHROME_USER_DATA_DIR=C:\Users\Your_User\AppData\Local\Google\Chrome\User Data\Profile_Name
CHROME_PROFILE_NAME=Profile_Name
BROWSER_HEADLESS=false
# Set BROWSER_HEADLESS=true after initial login setup is complete

# -----------------------------------------------------------------------------
# EMAIL CONFIGURATION (Gmail - Official API)
# -----------------------------------------------------------------------------
EMAIL_USER=your.email@gmail.com
GMAIL_CREDENTIALS_PATH=gmail_credentials.json
GMAIL_CHECK_INTERVAL=120

# -----------------------------------------------------------------------------
# WHATSAPP CONFIGURATION (Playwright - Uses Chrome Session)
# -----------------------------------------------------------------------------
WHATSAPP_ENABLED=true
WHATSAPP_SESSION_PATH=./sessions/whatsapp_session
WHATSAPP_CHECK_INTERVAL=60
WHATSAPP_KEYWORDS=urgent,asap,invoice,payment,help,emergency,critical,important

# -----------------------------------------------------------------------------
# LINKEDIN CONFIGURATION (Playwright - Uses Chrome Session)
# -----------------------------------------------------------------------------
LINKEDIN_ENABLED=true
LINKEDIN_USERNAME=your.linkedin.email@example.com
LINKEDIN_PASSWORD=your_linkedin_password
LINKEDIN_SESSION_PATH=./sessions/linkedin_session
LINKEDIN_CHECK_INTERVAL=3600

# -----------------------------------------------------------------------------
# FACEBOOK CONFIGURATION (Playwright - Uses Chrome Session)
# -----------------------------------------------------------------------------
FACEBOOK_ENABLED=true
FACEBOOK_USERNAME=your.facebook.email@example.com
FACEBOOK_PASSWORD=your_facebook_password
FACEBOOK_SESSION_PATH=./sessions/facebook_session
FACEBOOK_CHECK_INTERVAL=7200

# -----------------------------------------------------------------------------
# INSTAGRAM CONFIGURATION (Playwright - Uses Chrome Session)
# -----------------------------------------------------------------------------
INSTAGRAM_ENABLED=true
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password
INSTAGRAM_SESSION_PATH=./sessions/instagram_session
INSTAGRAM_CHECK_INTERVAL=7200

# -----------------------------------------------------------------------------
# TWITTER/X CONFIGURATION (Playwright - Uses Chrome Session)
# -----------------------------------------------------------------------------
TWITTER_ENABLED=true
TWITTER_USERNAME=your_twitter_username
TWITTER_PASSWORD=your_twitter_password
TWITTER_SESSION_PATH=./sessions/twitter_session
TWITTER_CHECK_INTERVAL=7200

# -----------------------------------------------------------------------------
# ODOO ACCOUNTING CONFIGURATION (Business Integration - CRITICAL FOR GOLD TIER)
# -----------------------------------------------------------------------------
ODOO_ENABLED=true
ODOO_URL=https://your-company.odoo.com
ODOO_DB=your-db
ODOO_USERNAME=your.email@example.com
ODOO_PASSWORD=your_odoo_password
ODOO_CHECK_INTERVAL=3600

# Odoo API Configuration (JSON-RPC)
ODOO_API_KEY=your_odoo_api_key
ODOO_COMPANY_ID=1
ODOO_CURRENCY_ID=2
ODOO_INVOICE_JOURNAL_ID=1

# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION (SQLite for local storage)
# -----------------------------------------------------------------------------
DATABASE_URL=sqlite:///elyx.db
DB_POOL_SIZE=10
DB_POOL_OVERFLOW=5
DB_ECHO=false

# -----------------------------------------------------------------------------
# SECURITY CONFIGURATION
# -----------------------------------------------------------------------------
SECRET_KEY=your_secret_key_here
JWT_SECRET=your_jwt_secret_here
APPROVAL_THRESHOLD=100

# -----------------------------------------------------------------------------
# AUDIT & LOGGING CONFIGURATION
# -----------------------------------------------------------------------------
OBSIDIAN_VAULT_PATH=obsidian_vault
BLOCKCHAIN_LOG_PATH=obsidian_vault/Blockchain_Integration/audit_trail.json
LOG_LEVEL=INFO
LOG_RETENTION_DAYS=30
STRUCTURED_LOGGING=true
SECURITY_LOGGING=true

# -----------------------------------------------------------------------------
# API SERVER CONFIGURATION
# -----------------------------------------------------------------------------
API_HOST=localhost
API_PORT=8000
API_WORKERS=4
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# -----------------------------------------------------------------------------
# FILESYSTEM WATCHER CONFIGURATION
# -----------------------------------------------------------------------------
FILESYSTEM_CHECK_INTERVAL=10
DROP_FOLDER_PATH=./file_drop

# -----------------------------------------------------------------------------
# FEATURE FLAGS (Enable/Disable specific capabilities)
# -----------------------------------------------------------------------------
# Core Features (Always recommended)
ENABLE_GMAIL_WATCHER=true
ENABLE_WHATSAPP_WATCHER=true
ENABLE_FILESYSTEM_WATCHER=true
ENABLE_ORCHESTRATOR=true
ENABLE_RALPH_LOOP=true

# Business Integration
ENABLE_ODOO_INTEGRATION=true
ENABLE_CEO_BRIEFING=true
ENABLE_APPROVAL_WORKFLOW=true

# Social Media (Enable only if you have credentials configured)
ENABLE_LINKEDIN_WATCHER=true
ENABLE_FACEBOOK_WATCHER=true
ENABLE_TWITTER_WATCHER=true
ENABLE_INSTAGRAM_WATCHER=true

# Advanced Features
ENABLE_ANALYTICS=true
ENABLE_LEARNING=true
ENABLE_CALENDAR_INTEGRATION=false
ENABLE_AUDIT_LOGGING=true
ENABLE_ACTION_SIGNING=true

# -----------------------------------------------------------------------------
# PERFORMANCE CONFIGURATION
# -----------------------------------------------------------------------------
MAX_CONCURRENT_AI_OPERATIONS=5
PARALLEL_PROCESSING_THREADS=4
MEMORY_LIMIT_PER_REQUEST=512MB
CACHE_SIZE=512MB

# -----------------------------------------------------------------------------
# WATCHDOG CONFIGURATION (Process monitoring)
# -----------------------------------------------------------------------------
WATCHDOG_CHECK_INTERVAL=60
WATCHDOG_AUTO_RESTART=true

# -----------------------------------------------------------------------------
# MCP SERVERS CONFIGURATION (Model Context Protocol)
# -----------------------------------------------------------------------------
EMAIL_MCP_ENABLED=true
EMAIL_MCP_PORT=8090
BROWSER_MCP_ENABLED=true
BROWSER_MCP_PORT=8091

# -----------------------------------------------------------------------------
# FRONTEND CONFIGURATION (Next.js Dashboard)
# -----------------------------------------------------------------------------
FRONTEND_API_URL=http://localhost:8000
FRONTEND_WS_URL=ws://localhost:8000
FRONTEND_BASE_URL=http://localhost:3000
FRONTEND_ENVIRONMENT=development
