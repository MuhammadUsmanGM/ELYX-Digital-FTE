{
  "mcpServers": {
    "email-mcp": {
      "command": "node",
      "args": ["src/mcp-servers/email-mcp/index.js"],
      "env": {
        "GMAIL_CREDENTIALS_PATH": "gmail_credentials.json",
        "EMAIL_USER": ""
      }
    },
    "odoo-mcp": {
      "command": "node",
      "args": ["src/mcp-servers/odoo-mcp/index.js"],
      "env": {
        "ODOO_URL": "https://elyx-ai.odoo.com",
        "ODOO_DB": "elyx-ai",
        "ODOO_USERNAME": "",
        "ODOO_PASSWORD": "",
        "ODOO_API_KEY": ""
      }
    },
    "social-mcp": {
      "command": "node",
      "args": ["src/mcp-servers/social-mcp/index.js"],
      "env": {
        "BROWSER_HEADLESS": "true",
        "CHROME_USER_DATA_DIR": ""
      }
    },
    "whatsapp-mcp": {
      "command": "node",
      "args": ["src/mcp-servers/whatsapp-mcp/index.js"],
      "env": {
        "BROWSER_HEADLESS": "true",
        "CHROME_USER_DATA_DIR": "",
        "WHATSAPP_KEYWORDS": "urgent,asap,invoice,payment,help,emergency,critical,important"
      }
    },
    "filesystem-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "@anthropic/mcp-filesystem",
        "obsidian_vault"
      ]
    }
  }
}
