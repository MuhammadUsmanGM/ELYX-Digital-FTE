{
  "vault_path": "obsidian_vault",
  "check_interval": {
    "gmail": 120,
    "whatsapp": 3600,
    "filesystem": 10,
    "calendar": 300,
    "orchestrator": 60,
    "linkedin": 3600,
    "facebook": 7200,
    "twitter": 7200,
    "instagram": 7200,
    "odoo": 3600
  },
  "watchdog": {
    "check_interval": 60,
    "auto_restart": true
  },
  "gmail": {
    "credentials_path": "gmail_credentials.json",
    "monitor_filters": ["is:unread is:important"]
  },
  "whatsapp": {
    "session_path": "~/.whatsapp_session",
    "keywords": ["urgent", "asap", "invoice", "payment", "help", "emergency", "critical", "important"]
  },
  "calendar": {
    "sync_enabled": false,
    "providers": ["google", "outlook"],
    "default_provider": "google",
    "sync_frequency_minutes": 15,
    "create_tasks_for_events": true
  },
  "silver_tier_features": {
    "enable_analytics": true,
    "enable_learning": true,
    "enable_advanced_monitoring": true,
    "enable_predictive_features": true,
    "enable_calendar_integration": false
  },
  "api": {
    "host": "localhost",
    "port": 8000,
    "workers": 4,
    "cors_origins": ["*"]
  },
  "database": {
    "url": "sqlite:///silver_tier.db",
    "pool_size": 20,
    "pool_overflow": 10,
    "echo": false
  },
  "security": {
    "require_approval_for": [
      "payments",
      "emails_to_new_contacts",
      "file_sharing",
      "access_changes",
      "confidential_info"
    ],
    "approval_threshold": 100
  },
  "logging": {
    "level": "INFO",
    "file_logging": true,
    "log_retention_days": 30,
    "structured_logging": true
  },
  "mcp_servers": {
    "email_mcp": {
      "enabled": true,
      "port": 8080,
      "host": "localhost"
    },
    "browser_mcp": {
      "enabled": true,
      "port": 8081,
      "host": "localhost"
    }
  },
  "obsidian_integration": {
    "enable_realtime_sync": true,
    "dashboard_refresh_interval": 30,
    "use_obsidian_links": true,
    "enable_dataview_queries": true
  },
  "integrations": {
    "calendar_enabled": false,
    "crm_enabled": false,
    "project_management_enabled": false,
    "use_claude_cli": true,
    "ralph_loop_enabled": true,
    "facebook_enabled": true,
    "twitter_enabled": true,
    "instagram_enabled": true,
    "odoo_enabled": true
  },
  "platinum_tier_features": {
    "enable_quantum_security": true,
    "enable_blockchain_accountability": true,
    "enable_global_operations": true,
    "enable_federated_learning": true,
    "replication_factor": 3
  },
  "global_scaling": {
    "regional_endpoints": [
      "http://us-east-1.elyx.ai",
      "http://eu-west-1.elyx.ai",
      "http://ap-southeast-1.elyx.ai",
      "http://sa-east-1.elyx.ai",
      "http://ca-central-1.elyx.ai"
    ],
    "failover_priority": ["us-east-1", "eu-west-1", "ap-southeast-1"]
  },
  "blockchain": {
    "log_path": "obsidian_vault/Blockchain_Integration/audit_trail.json",
    "network": "ELYX-Private-Mainnet"
  },
  "consciousness_simulation_features": {
    "enable_consciousness_emergence": true,
    "enable_reality_simulation": true,
    "enable_existential_reasoning": true,
    "self_awareness_threshold": 0.85,
    "reality_fidelity_target": 9.5
  },
  "brain_selection": {
    "active_brain": "claude",
    "brains": {
      "claude": {
        "command": "claude",
        "args": ["-p"],
        "description": "Anthropic Claude Code - Strategic reasoning and execution"
      },
      "qwen": {
        "command": "qwen",
        "args": ["-p"],
        "description": "Alibaba Qwen Coder - Fast local coding tasks"
      },
      "gemini": {
        "command": "gemini",
        "args": ["-p"],
        "description": "Google Gemini CLI - High-volume triage and analysis"
      },
      "codex": {
        "command": "codex",
        "args": ["-p"],
        "description": "OpenAI Codex CLI - Code generation and refactoring"
      }
    }
  }
}