{
  "vault_path": "obsidian_vault",
  "check_interval": {
    "gmail": 120,
    "whatsapp": 3600,
    "filesystem": 10,
    "calendar": 300,
    "orchestrator": 60,
    "linkedin": 3600,
    "facebook": 7200,
    "twitter": 7200,
    "instagram": 7200,
    "odoo": 3600
  },
  "watchdog": {
    "check_interval": 60,
    "auto_restart": true
  },
  "gmail": {
    "credentials_path": "gmail_credentials.json",
    "monitor_filters": [
      "is:unread is:important"
    ]
  },
  "whatsapp": {
    "session_path": "~/.whatsapp_session",
    "keywords": [
      "urgent",
      "asap",
      "invoice",
      "payment",
      "help",
      "emergency",
      "critical",
      "important"
    ]
  },
  "calendar": {
    "sync_enabled": false,
    "providers": [
      "google",
      "outlook"
    ],
    "default_provider": "google",
    "sync_frequency_minutes": 15,
    "create_tasks_for_events": true
  },
  "silver_tier_features": {
    "enable_analytics": true,
    "enable_learning": true,
    "enable_advanced_monitoring": true,
    "enable_predictive_features": true,
    "enable_calendar_integration": false
  },
  "api": {
    "host": "localhost",
    "port": 8000,
    "workers": 4,
    "cors_origins": [
      "*"
    ]
  },
  "database": {
    "url": "sqlite:///silver_tier.db",
    "pool_size": 20,
    "pool_overflow": 10,
    "echo": false
  },
  "security": {
    "require_approval_for": [
      "payments",
      "emails_to_new_contacts",
      "file_sharing",
      "access_changes",
      "confidential_info"
    ],
    "approval_threshold": 100
  },
  "logging": {
    "level": "INFO",
    "file_logging": true,
    "log_retention_days": 30,
    "structured_logging": true
  },
  "mcp_servers": {
    "email_mcp": {
      "enabled": true,
      "port": 8080,
      "host": "localhost"
    },
    "browser_mcp": {
      "enabled": true,
      "port": 8081,
      "host": "localhost"
    }
  },
  "obsidian_integration": {
    "enable_realtime_sync": true,
    "dashboard_refresh_interval": 30,
    "use_obsidian_links": true,
    "enable_dataview_queries": true
  },
  "integrations": {
    "gmail_enabled": true,
    "whatsapp_enabled": true,
    "linkedin_enabled": false,
    "facebook_enabled": false,
    "twitter_enabled": false,
    "instagram_enabled": false,
    "calendar_enabled": false,
    "crm_enabled": false,
    "project_management_enabled": false,
    "use_claude_cli": true,
    "ralph_loop_enabled": true,
    "odoo_enabled": true
  },
  "audit": {
    "enable_action_signing": true,
    "enable_audit_logging": true,
    "log_path": "obsidian_vault/Blockchain_Integration/audit_trail.json"
  },
  "backup": {
    "enabled": false,
    "sync_targets": []
  },
  "experimental": {
    "enable_consciousness_emergence": false,
    "enable_reality_simulation": false,
    "enable_existential_reasoning": false,
    "note": "These modules are research prototypes and not recommended for production use"
  },
  "brain_selection": {
    "active_brain": "claude",
    "brains": {
      "claude": {
        "command": "claude",
        "args": [
          "-p"
        ],
        "description": "Anthropic Claude Code - PRIMARY BRAIN per hackathon spec. Strategic reasoning, autonomous operation via Ralph Wiggum loop."
      },
      "qwen": {
        "command": "C:\\Users\\Usman Mustafa\\AppData\\Roaming\\npm\\qwen.cmd",
        "args": [
          "--yolo"
        ],
        "description": "Alibaba Qwen Coder - Alternative brain. Fast coding tasks. (Optional)"
      },
      "gemini": {
        "command": "C:\\Users\\Usman Mustafa\\AppData\\Roaming\\npm\\gemini.cmd",
        "args": [
          "-p"
        ],
        "description": "Google Gemini CLI - NOT INSTALLED. Run: npm i -g @google/gemini-cli"
      },
      "codex": {
        "command": "codex",
        "args": [
          "exec"
        ],
        "description": "OpenAI Codex CLI - Alternative brain. Code generation. (Optional)"
      }
    }
  }
}