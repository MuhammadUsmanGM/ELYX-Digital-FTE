      "mcp__filesystem_mcp__list_directory",
      "Bash(cd C:\\\\Users\\\\Usman Mustafa\\\\OneDrive\\\\Desktop\\\\ELYX-Personal-AI-Employee:*)",
      "Bash(python3:*)",
      "WebSearch",
      "WebFetch(domain:www.thecaio.ai)",
      "WebFetch(domain:playbooks.com)",
      "Bash(cd:*)",
      "Bash(grep:*)",
      "Bash(node:*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python scripts/ralph_stop_hook.py"
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "email-mcp": {
      "command": "node",
      "args": [
        "src/mcp-servers/email-mcp/index.js"
      ],
      "env": {
        "GMAIL_CREDENTIALS_PATH": "gmail_credentials.json",
        "EMAIL_USER": ""
      }
    },
    "odoo-mcp": {
      "command": "node",
      "args": [
        "src/mcp-servers/odoo-mcp/index.js"
      ],
      "env": {
        "ODOO_URL": "https://elyx-ai.odoo.com",
        "ODOO_DB": "elyx-ai",
        "ODOO_USERNAME": "",
        "ODOO_PASSWORD": "",
        "ODOO_API_KEY": ""
      }
    },
    "social-mcp": {
      "command": "node",
      "args": [
        "src/mcp-servers/social-mcp/index.js"
      ],
      "env": {
        "BROWSER_HEADLESS": "true",
        "CHROME_USER_DATA_DIR": ""
      }
    },
    "whatsapp-mcp": {
      "command": "node",
      "args": [
        "src/mcp-servers/whatsapp-mcp/index.js"
      ],
      "env": {
        "BROWSER_HEADLESS": "true",
        "CHROME_USER_DATA_DIR": "",
        "WHATSAPP_KEYWORDS": "urgent,asap,invoice,payment,help,emergency,critical,important"
      }
    },
    "filesystem-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "@anthropic/mcp-filesystem",
        "obsidian_vault"
      ]
    }
  }
}
